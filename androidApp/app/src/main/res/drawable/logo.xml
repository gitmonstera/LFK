<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="200"
    android:viewportHeight="200">

    <!-- ========== БАЗОВОЕ СВЕЧЕНИЕ ========== -->
    <path
        android:pathData="M100,100 m-75,0 a75,75 0 1,1 150,0 a75,75 0 1,1 -150,0"
        android:fillAlpha="0.08">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="100"
                android:centerY="100"
                android:gradientRadius="75">
                <item android:offset="0" android:color="#FF764BA2" />
                <item android:offset="0.7" android:color="#FF667EEA" />
                <item android:offset="1" android:color="#00000000" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- ========== СПИРАЛИ ДНК (фон, наука) ========== -->
    <!-- Левая спираль -->
    <path
        android:pathData="M70,45 Q52,72 70,100 Q88,128 70,155"
        android:strokeWidth="2.5"
        android:strokeColor="#FF667EEA"
        android:strokeAlpha="0.3"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />

    <path
        android:pathData="M70,60 Q58,82 70,105 Q82,128 70,148"
        android:strokeWidth="1.5"
        android:strokeColor="#FF667EEA"
        android:strokeAlpha="0.2"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />

    <!-- Правая спираль -->
    <path
        android:pathData="M130,45 Q148,72 130,100 Q112,128 130,155"
        android:strokeWidth="2.5"
        android:strokeColor="#FF764BA2"
        android:strokeAlpha="0.3"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />

    <path
        android:pathData="M130,60 Q142,82 130,105 Q118,128 130,148"
        android:strokeWidth="1.5"
        android:strokeColor="#FF764BA2"
        android:strokeAlpha="0.2"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />

    <!-- ========== ЦЕНТРАЛЬНАЯ ФИГУРА ========== -->

    <!-- Голова (кристалл) -->
    <path
        android:pathData="M100,38 L113,47 L100,56 L87,47 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="87"
                android:startY="38"
                android:endX="113"
                android:endY="56"
                android:type="linear">
                <item android:offset="0" android:color="#FF667EEA" />
                <item android:offset="1" android:color="#FF764BA2" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Позвоночник -->
    <path
        android:pathData="M100,56 L100,145"
        android:strokeWidth="4"
        android:strokeColor="#FFFFFF"
        android:strokeAlpha="0.2"
        android:strokeLineCap="round" />

    <!-- ========== СЕРДЦЕ ========== -->
    <path
        android:pathData="M100,80
                 C72,57 44,80 44,108
                 C44,133 72,155 100,168
                 C128,155 156,133 156,108
                 C156,80 128,57 100,80 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="44"
                android:startY="57"
                android:endX="156"
                android:endY="168"
                android:type="linear">
                <item android:offset="0" android:color="#FF667EEA" />
                <item android:offset="0.5" android:color="#FF764BA2" />
                <item android:offset="1" android:color="#FF9F7AEA" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Линия пульса (ЭКГ) -->
    <path
        android:pathData="M64,115 L82,115 L88,100 L94,128 L100,110 L106,122 L112,105 L118,115 L136,115"
        android:strokeWidth="2.2"
        android:strokeColor="#FFD700"
        android:strokeAlpha="0.8"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />
</vector>