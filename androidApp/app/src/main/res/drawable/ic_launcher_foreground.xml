          android:strokeColor="#FFD700"
          android:strokeAlpha="0.9"
          android:strokeLineCap="round"
          android:fillColor="#00000000" />


      <!-- Левая рука (тянется вверх - стремление) -->
      <path
          android:pathData="M100,70 C85,70 70,65 60,50"
          android:strokeWidth="5"
          android:strokeColor="#FF667EEA"
          android:strokeLineCap="round" />

      <!-- Левая кисть с пальцами -->
      <path
          android:pathData="M55,45 L48,40 L52,35"
          android:strokeWidth="3"
          android:strokeColor="#FF667EEA"
          android:strokeLineCap="round" />

      <!-- Правая рука (опирается на бедро - стабильность) -->
      <path
          android:pathData="M100,85 C115,90 130,95 138,110"
          android:strokeWidth="5"
          android:strokeColor="#FF764BA2"
          android:strokeLineCap="round" />

      <!-- Правая кисть -->
      <path
          android:pathData="M140,115 L148,112 L152,120"
          android:strokeWidth="3"
          android:strokeColor="#FF764BA2"
          android:strokeLineCap="round" />

      <!-- Левая нога (шаг вперед - прогресс) -->
      <path
          android:pathData="M100,145 C95,160 85,175 75,185"
          android:strokeWidth="5"
          android:strokeColor="#FF667EEA"
          android:strokeLineCap="round" />

      <!-- Правая нога (опора) -->
      <path
          android:pathData="M100,145 C110,160 120,170 130,180"
          android:strokeWidth="5"
          android:strokeColor="#FF764BA2"
          android:strokeLineCap="round" />


      <!-- Суставы (точки опоры) -->
      <path
          android:pathData="M100,70 m-3,0 a3,3 0 1,1 6,0 a3,3 0 1,1 -6,0"
          android:fillColor="#FFD700"
          android:fillAlpha="0.6" />

      <path
          android:pathData="M100,145 m-3,0 a3,3 0 1,1 6,0 a3,3 0 1,1 -6,0"
          android:fillColor="#FFD700"
          android:fillAlpha="0.6" />


      <!-- Атомная орбита (символ науки и движения) -->
      <path
          android:pathData="M40,40 Q70,20 100,40 Q130,60 160,40"
          android:strokeWidth="1.5"
          android:strokeColor="#FFFFFF"
          android:strokeAlpha="0.15"
          android:strokeLineCap="round"
          android:fillColor="#00000000" />

      <path
          android:pathData="M40,160 Q70,180 100,160 Q130,140 160,160"
          android:strokeWidth="1.5"
          android:strokeColor="#FFFFFF"
          android:strokeAlpha="0.15"
          android:strokeLineCap="round"
          android:fillColor="#00000000" />

      <!-- Тонкие линии, обозначающие мышцы/волокна -->
      <path
          android:pathData="M90,120 L95,130"
          android:strokeWidth="1"
          android:strokeColor="#80FFFFFF"
          android:strokeAlpha="0.3" />
      <path
          android:pathData="M110,120 L105,130"
          android:strokeWidth="1"
          android:strokeColor="#80FFFFFF"
          android:strokeAlpha="0.3" />


  </group>
