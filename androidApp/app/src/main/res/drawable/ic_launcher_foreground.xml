<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="200"
    android:viewportHeight="200">
  <group android:scaleX="0.61448276"
      android:scaleY="0.61448276"
      android:translateX="38.551723"
      android:translateY="33.431034">

      <!-- Эффект глубины: радиальное свечение -->
      <path
          android:pathData="M100,100 m-80,0 a80,80 0 1,1 160,0 a80,80 0 1,1 -160,0"
          android:fillAlpha="0.1">
          <aapt:attr name="android:fillColor">
              <gradient
                  android:startX="20"
                  android:startY="20"
                  android:endX="180"
                  android:endY="180"
                  android:type="radial">
                  <item android:offset="0" android:color="#FF764BA2" />
                  <item android:offset="0.7" android:color="#FF667EEA" />
                  <item android:offset="1" android:color="#00000000" />
              </gradient>
          </aapt:attr>
      </path>


      <!-- Левая спираль ДНК (символ науки и структуры тела) -->
      <path
          android:pathData="M70,40 Q50,70 70,100 Q90,130 70,160"
          android:strokeWidth="4"
          android:strokeColor="#FF667EEA"
          android:strokeLineCap="round"
          android:strokeAlpha="0.8"
          android:fillColor="#00000000" />

      <path
          android:pathData="M70,55 Q55,80 70,105 Q85,130 70,155"
          android:strokeWidth="2"
          android:strokeColor="#FF667EEA"
          android:strokeLineCap="round"
          android:strokeAlpha="0.4"
          android:fillColor="#00000000" />

      <!-- Правая спираль ДНК -->
      <path
          android:pathData="M130,40 Q150,70 130,100 Q110,130 130,160"
          android:strokeWidth="4"
          android:strokeColor="#FF764BA2"
          android:strokeLineCap="round"
          android:strokeAlpha="0.8"
          android:fillColor="#00000000" />

      <path
          android:pathData="M130,55 Q145,80 130,105 Q115,130 130,155"
          android:strokeWidth="2"
          android:strokeColor="#FF764BA2"
          android:strokeLineCap="round"
          android:strokeAlpha="0.4"
          android:fillColor="#00000000" />

      <!-- Голова (кристалл здоровья) -->
      <path
          android:pathData="M100,35 L115,45 L100,55 L85,45 Z">
          <aapt:attr name="android:fillColor">
              <gradient
                  android:startX="85"
                  android:startY="35"
                  android:endX="115"
                  android:endY="55"
                  android:type="linear">
                  <item android:offset="0" android:color="#FF667EEA" />
                  <item android:offset="1" android:color="#FF764BA2" />
              </gradient>
          </aapt:attr>
      </path>

      <!-- Блик на голове -->
      <path
          android:pathData="M95,42 L105,42 L100,48 Z"
          android:fillColor="#80FFFFFF"
          android:fillAlpha="0.4" />

      <!-- Позвоночник/Ось (символ стержня) -->
      <path
          android:pathData="M100,55 L100,145"
          android:strokeWidth="5"
          android:strokeColor="#FFFFFF"
          android:strokeAlpha="0.2"
          android:strokeLineCap="round" />

      <!-- Сердце (медицинский символ) с идеальной формой -->
      <path
          android:pathData="M100,85
                   C70,60 40,85 40,115
                   C40,140 70,160 100,175
                   C130,160 160,140 160,115
                   C160,85 130,60 100,85 Z">
          <aapt:attr name="android:fillColor">
              <gradient
                  android:startX="40"
                  android:startY="60"
                  android:endX="160"
                  android:endY="175"
                  android:type="linear">
                  <item android:offset="0" android:color="#FF667EEA" />
                  <item android:offset="0.5" android:color="#FF764BA2" />
                  <item android:offset="1" android:color="#FF9F7AEA" />
              </gradient>
          </aapt:attr>
      </path>


      <!-- Линия пульса (ЭКГ) внутри сердца -->
      <path
          android:pathData="M70,120 L85,120 L90,105 L95,135 L100,115 L105,125 L110,110 L115,120 L130,120"
